{
  "name": "ts-manim",
  "version": "0.1.0",
  "description": "TypeScript animation framework for Node.js - Manim-inspired video generation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "anim": "./dist/cli/render.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "render": "node dist/cli/render.js",
    "example": "npm run build && node dist/cli/render.js render dist/examples/sample-scene.js",
    "dev:preview": "cd dev-server && npm install && npm start"
  },
  "keywords": [
    "animation",
    "video",
    "manim",
    "typescript",
    "skia",
    "ffmpeg"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "skia-canvas": "^1.0.1",
    "commander": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
